{
  "name": "sleck",
  "version": "0.1.0",
  "private": true,
  "description": "Group chat platform inspired by Slack and Discord",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/backend",
    "dev:frontend": "npm run dev --workspace=@sleck/frontend",
    "build": "npm run build --workspaces --if-present",
    "build:frontend": "npm run build --workspace=@sleck/frontend",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint:frontend": "npm run lint --workspace=@sleck/frontend"
  },
  "keywords": [
    "chat",
    "real-time",
    "collaboration"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
