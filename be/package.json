{
  "name": "sleck-backend",
  "version": "0.1.0",
  "description": "Sleck backend scaffold (Express + tRPC)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:generate": "npx drizzle-kit generate:pg",
    "migrate:push": "npx drizzle-kit push:pg",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.19.2",
    "@trpc/server": "^11.16.0",
    "dotenv": "^16.4.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
