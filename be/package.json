{
  "name": "sleck-backend",
  "version": "0.1.0",
  "description": "Sleck backend scaffold (Express + tRPC)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:generate": "npx drizzle-kit generate:pg",
    "migrate:push": "npx drizzle-kit push:pg",
    "test": "jest"
  },
  "dependencies": {
    "@trpc/server": "^11.16.0",
    "drizzle-orm": "^0.29.5",
    "express": "^4.19.2",
    "pg": "^8.11.3",
    "zod": "^3.22.4",
    "dotenv-safe": "^9.0.0"
  },
  "devDependencies": {
    "@types/dotenv-safe": "^9.1.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
